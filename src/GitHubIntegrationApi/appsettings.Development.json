{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "WcfServiceUrl": "http://github-integration-service:8080/GitHubService.svc",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app_data/Logs/api-log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
